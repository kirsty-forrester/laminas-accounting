// Build the account options HTML once for JavaScript to reuse
$optionsHtml = '<option value="">-- Select Account --</option>';
foreach ($accounts as $account) {
    $optionsHtml .= sprintf(
        '<option value="%d">%s</option>',
        $account->getAccountId(),
        $this->escapeHtml($account->getName()),
    );
}
?>

<script>
(function () {
    var accountOptions = <?= json_encode($optionsHtml) ?>;
    var tbody = document.getElementById('entries-body');
    var rowIndex = 2;

    document.getElementById('add-row').addEventListener('click', function () {
        var tr = document.createElement('tr');
        tr.className = 'entry-row';
        tr.innerHTML =
            '<td><select class="form-control" name="entries[' + rowIndex + '][account_id]" required>'
                + accountOptions + '</select></td>'
            + '<td><input type="text" class="form-control debit-input" name="entries[' + rowIndex + '][debit]" placeholder="0.00"></td>'
            + '<td><input type="text" class="form-control credit-input" name="entries[' + rowIndex + '][credit]" placeholder="0.00"></td>'
            + '<td><button type="button" class="btn btn-sm btn-danger remove-row">-</button></td>';
        tbody.appendChild(tr);
        rowIndex++;
        updateTotals();
    });

    tbody.addEventListener('click', function (e) {
        if (e.target.classList.contains('remove-row')) {
            var rows = tbody.querySelectorAll('.entry-row');
            if (rows.length > 2) {
                e.target.closest('tr').remove();
                updateTotals();
            }
        }
    });

    tbody.addEventListener('input', function (e) {
        if (e.target.classList.contains('debit-input')
            || e.target.classList.contains('credit-input')) {
            updateTotals();
        }
    });

    function parsePennies(value) {
        var f = parseFloat(value);
        if (isNaN(f)) return 0;
        return Math.round(f * 100);
    }

    function updateTotals() {
        var debits = 0;
        var credits = 0;

        document.querySelectorAll('.debit-input').forEach(function (input) {
            debits += parsePennies(input.value);
        });
        document.querySelectorAll('.credit-input').forEach(function (input) {
            credits += parsePennies(input.value);
        });

        document.getElementById('total-debits').textContent = (debits / 100).toFixed(2);
        document.getElementById('total-credits').textContent = (credits / 100).toFixed(2);

        var balanced = debits === credits && debits > 0;
        document.getElementById('post-btn').disabled = !balanced;
        document.getElementById('balance-warning').style.display =
            (debits > 0 || credits > 0) && !balanced ? '' : 'none';
    }
})();
</script>