<?php

$title = 'New Journal Entry';
$this->headTitle($title);

$form->setAttribute('action', $this->url('journal', ['action' => 'add']));
$form->prepare();

$lines = $form->get('lines');

// Render one line as a table row. Used for both the real rows and the
// collection's __index__ template row, so their markup stays identical.
$renderRow = function ($line) {
    ob_start();
    ?>
    <tr class="entry-row">
        <td>
            <?= $this->formHidden($line->get('journal_entry_line_id')) ?>
            <?= $this->formElement($line->get('account_id')->setAttribute('class', 'form-control')) ?>
        </td>
        <td><?= $this->formElement($line->get('debit')) ?></td>
        <td><?= $this->formElement($line->get('credit')) ?></td>
        <td><button type="button" class="btn btn-sm btn-danger remove-row">-</button></td>
    </tr>
    <?php
    return ob_get_clean();
};
?>
<h1><?= $this->escapeHtml($title) ?></h1>

<?= $this->form()->openTag($form) ?>

<div class="form-group mb-3">
    <?= $this->formLabel($form->get('date')) ?>
    <?= $this->formElement($form->get('date')->setAttribute('class', 'form-control')) ?>
    <?= $this->formElementErrors($form->get('date'), ['class' => 'text-danger']) ?>
</div>

<div class="form-group mb-3">
    <?= $this->formLabel($form->get('description')) ?>
    <?= $this->formElement($form->get('description')->setAttribute('class', 'form-control')) ?>
    <?= $this->formElementErrors($form->get('description'), ['class' => 'text-danger']) ?>
</div>

<table class="table" id="entries-table">
    <thead>
        <tr>
            <th>Account</th>
            <th>Debit</th>
            <th>Credit</th>
            <th></th>
        </tr>
    </thead>
    <tbody id="entries-body">
        <?php foreach ($lines as $line) : ?>
            <?= $renderRow($line) ?>
        <?php endforeach; ?>
    </tbody>
    <tfoot>
        <tr>
            <th>Totals</th>
            <th id="total-debits">0.00</th>
            <th id="total-credits">0.00</th>
            <th></th>
        </tr>
    </tfoot>
</table>

<div class="mb-3">
    <button type="button" class="btn btn-secondary" id="add-row">+ Add Line</button>
</div>

<p id="balance-warning" class="text-danger" style="display:none;">
    Debits and credits must be equal.
</p>

<?= $this->formHidden($form->get('journal_entry_id')) ?>
<?= $this->formSubmit($form->get('submit')
        ->setAttribute('class', 'btn btn-primary')
        ->setAttribute('id', 'post-btn')) ?>

<?= $this->form()->closeTag() ?>

<?php
// The collection emits a __index__ template row; the JS clones it for new lines,
// substituting the running index into the field names (lines[2][debit], ...).
$templateRow = $renderRow($lines->getTemplateElement());
?>
<script>
(function () {
    var template = <?= json_encode($templateRow) ?>;
    var tbody    = document.getElementById('entries-body');
    var rowIndex = <?= count($lines) ?>;

    document.getElementById('add-row').addEventListener('click', function () {
        var holder = document.createElement('tbody');
        holder.innerHTML = template.replace(/__index__/g, rowIndex);
        tbody.appendChild(holder.firstElementChild);
        rowIndex++;
        updateTotals();
    });

    tbody.addEventListener('click', function (e) {
        if (e.target.classList.contains('remove-row')) {
            var rows = tbody.querySelectorAll('.entry-row');
            if (rows.length > 2) {
                e.target.closest('tr').remove();
                updateTotals();
            }
        }
    });

    tbody.addEventListener('input', function (e) {
        if (e.target.classList.contains('debit-input')
            || e.target.classList.contains('credit-input')) {
            updateTotals();
        }
    });

    function parsePennies(value) {
        var f = parseFloat(value);
        return isNaN(f) ? 0 : Math.round(f * 100);
    }

    function updateTotals() {
        var debits = 0, credits = 0;
        document.querySelectorAll('.debit-input').forEach(function (i) { debits += parsePennies(i.value); });
        document.querySelectorAll('.credit-input').forEach(function (i) { credits += parsePennies(i.value); });

        document.getElementById('total-debits').textContent = (debits / 100).toFixed(2);
        document.getElementById('total-credits').textContent = (credits / 100).toFixed(2);

        var balanced = debits === credits && debits > 0;
        document.getElementById('post-btn').disabled = !balanced;
        document.getElementById('balance-warning').style.display =
            (debits > 0 || credits > 0) && !balanced ? '' : 'none';
    }

    updateTotals();
})();
</script>
