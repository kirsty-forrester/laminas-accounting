<?php

use Accounting\ValueObject\AccountType;

$title = 'Chart of Accounts';
$this->headTitle($title);

// Group accounts by their type value.
$byType = [];
foreach ($this->accounts as $account) {
    $byType[$account->getType()->value][] = $account;
}

// Standard accounting display order.
$order = [
    AccountType::Asset,
    AccountType::Liability,
    AccountType::Equity,
    AccountType::Income,
    AccountType::Expense,
];
?>
<h1><?= $this->escapeHtml($title) ?></h1>

<p>
    <a href="<?= $this->url('accounts/add') ?>" class="btn btn-primary">Add New Account</a>
</p>

<?php foreach ($order as $type) : ?>
    <?php $group = $byType[$type->value] ?? []; ?>
    <?php if (! $group) { continue; } ?>

    <section class="account-group" style="--accent: <?= $this->escapeHtmlAttr($this->accountType()->colour($type)) ?>;">
        <h2 class="account-group-title"><?= $this->escapeHtml($this->accountType()->heading($type)) ?></h2>

        <table class="table table-striped align-middle account-table">
            <thead>
                <tr>
                    <th>Name</th>
                    <th class="text-end">Balance</th>
                    <th class="text-end">Actions</th>
                </tr>
            </thead>
            <tbody>
            <?php foreach ($group as $account) : ?>
                <?php $balance = $balances[$account->getAccountId()] ?? null; ?>
                <tr>
                    <td><?= $this->escapeHtml($account->getName()) ?></td>
                    <td class="text-end"><?= $balance ? $this->escapeHtml($balance->format()) : '' ?></td>
                    <td class="text-end">
                        <a href="<?= $this->url('accounts/view', ['id' => $account->getAccountId()]) ?>"
                           class="btn btn-sm btn-outline-secondary">View</a>
                        <a href="<?= $this->url('accounts/edit', ['id' => $account->getAccountId()]) ?>"
                           class="btn btn-sm btn-primary">Edit</a>
                        <a href="<?= $this->url('accounts/delete', ['id' => $account->getAccountId()]) ?>"
                           class="btn btn-sm btn-danger">Delete</a>
                    </td>
                </tr>
            <?php endforeach; ?>
            </tbody>
        </table>
    </section>
<?php endforeach; ?>
